# ===================================================================
# .gitignore for a Bioinformatics / Phylogenetics Project
# ===================================================================

# 1. DATA AND RESULTS
# -------------------
# This is the most important section.
# Ignore the entire data directory, as all large files will be downloaded 
# from Zenodo using the provided script.
# This prevents accidental commits of large data files.
data/
results/
processed_data/


# 2. SNAKEMAKE-SPECIFIC
# ---------------------
# Ignore the hidden .snakemake directory, which contains logs, metadata,
# and other tracking files that are not part of the source code.
.snakemake/


# 3. PYTHON-SPECIFIC
# ------------------
# Ignore Python caches, compiled files, and virtual environments.
__pycache__/
*.pyc
*.pyo
.venv/
venv/
env/
*.egg-info/
dist/
build/


# 4. R & RSTUDIO-SPECIFIC
# -----------------------
# Ignore RStudio project files, session history, and workspace data.
.Rproj.user/
.Rhistory
.RData
.Renviron
# Ignore any user-specific R library folders if they are created locally.
*~


# 5. QUARTO & MARKDOWN-SPECIFIC
# -----------------------------
# Ignore Quarto/Knitr caches and intermediate files.
_freeze/
_quarto/
*.html
*.pdf
# (Unless you want to commit the rendered HTML/PDF reports, but it's better practice not to)
_site/


# 6. OPERATING SYSTEM & EDITOR JUNK
# ---------------------------------
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini

# General Editor/IDE files
.vscode/
.idea/
*.swp
*.swo


# 7. LOG FILES
# ------------
# Ignore any log files generated by your scripts or HPC jobs.
*.log
*.log.*
*.out
*.err


