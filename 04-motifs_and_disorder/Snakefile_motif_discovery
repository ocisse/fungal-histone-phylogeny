import re
from glob import glob

def sanitize(s):
    # Allow letters, digits, dash, underscore, dot, comma; replace others with '_'
    return re.sub(r"[^\w\-\.,]", "_", s)


# Gather and sanitize cluster IDs from filenames
cluster_fastas = glob("../../data/processed/phylogeny/histones/motifs/clustering/cdhit_cluster_fastas/cluster_*.fasta")
clusters = sorted(
    sanitize(f.split("/")[-1][len("cluster_") : -len(".fasta")]) for f in cluster_fastas
)

print("CLUSTERS:", clusters)

rule all:
    input:
        expand("../../data/processed/phylogeny/histones/motifs/clustering/glam2_out/{cluster}/.done", cluster=clusters)

rule glam2_per_cluster:
    input:
        lambda wc: f"../../data/processed/phylogeny/histones/motifs/clustering/clusters_out/cluster_{wc.cluster}.fasta"
    output:
  #out_dir = directory("../../data/processed/phylogeny/histones/motifs/clustering/glam2_out/{cluster}")
        done = "../../data/processed/phylogeny/histones/motifs/clustering/glam2_out/{cluster}/.done"
    params:
      w = "5",
      a = "p",
      out_dir = lambda wc: f"../../data/processed/phylogeny/histones/motifs/clustering/clusters_out/cluster_{wc.cluster}"
    shell:
        """
        mkdir -p {output.done.dirname}
        glam2 {params.a} {input} -O {params.done.dirname} -w {params.w}
        touch {output.done}
        """
