configfile: "rules/config.yaml"

rule dealign:
    input:
        "../../data/processed/phylogeny/histones/alignments/Histone_Curated_Alignment_Unique_Ids_NTERM_revised.fasta"
    output:
        "../../data/processed/phylogeny/histones/motifs/clustering/CenH3_NTERM_dealigned.fasta"
    shell:
      """
      python ../scripts/dealign_fasta.py {input} {output}
      """


# step1:	Clusters sequences

#module load mmseqs
rule cluster:
    input:
        rules.dealign.output
    output:
        "../../data/processed/phylogeny/histones/motifs/clustering/CenH3_NTERM"
    threads: 4
    params:
        tmpdir = config["tmpdir"],
        id = "0.4",
        c = "0.4",
        cov = "0"
    shell:
        """
          touch {output} &&
          mmseqs easy-cluster {input} {output} {params.tmpdir} --min-seq-id {params.id} -c {params.c} --cov-mode {params.cov} --threads {threads}
        """
### overall MMSEQS is not optmial for short sequences, it failed to cluster known sequences (i.e. CENP-A from fission yeasts)
# module load cd-hit

rule cluster_cdhit:
    input:
        rules.dealign.output
    output:
        "../../data/processed/phylogeny/histones/motifs/clustering/CenH3_NTERM_CDHIT"
    threads: 4
    params:
        tmpdir = config["tmpdir"],
        id = "0.6",
        de = "0",
        w = "3" # word size
    shell:
        """
          touch {output} &&
          cd-hit -i {input} -o {output} -c {params.id} -d {params.de} -n {params.w}  -T {threads}
        """
# much better

