rule iqtree_HFD:
    input:
        "../../data/processed/phylogeny/histones/alignments/Histone_Curated_Alignment_Unique_Ids_HFD.fasta"
    output:
        treefile = "../../data/processed/phylogeny/histones/HFD_no_partition.treefile",
        log = "../../data/processed/phylogeny/histones/HFD_no_partition.log",
        iqtree = "../../data/processed/phylogeny/histones/HFD_no_partition.iqtree"
    threads: 12
    params:
        m = "MFP",
        b = "1000",
        a = "1000",
        prefix = "../../data/processed/phylogeny/histones/HFD_no_partition"
    shell:
        """
        ../tools/iqtree-3.0.1-Linux/bin/iqtree3 \
            -s {input} \
            -m {params.m} \
            -B {params.b} \
            -alrt {params.a} \
            -nt {threads} \
            -v \
            --prefix {params.prefix}
        """

