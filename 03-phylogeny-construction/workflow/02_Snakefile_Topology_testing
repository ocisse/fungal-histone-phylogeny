rule Nterm_topology_testing:
    input:
        aln = "../../data/processed/phylogeny/histones/NTERM_IQTREE/topology_testing/Histone_Curated_Alignment_Unique_Ids_NTERM_revised_CenH3_shared_sequences_NR.fasta",
        trees = rules.combine_nterm_cons_and_uncons_tree.output
    output:
        test = "../../data/processed/phylogeny/histones/NTERM_IQTREE/topology_testing/NTERM_topology_test.iqtree"
    threads: 6
    params:
        n = "0",
        zb = "10000",
        prefix = "../../data/processed/phylogeny/histones/NTERM_IQTREE/topology_testing/NTERM_topology_test"
    shell:
        """
        ../tools/iqtree-3.0.1-Linux/bin/iqtree3 \
            -s {input.aln} \
            -z {input.trees} \
            -n {params.n} \
            -zb {params.zb} \
            -zw \
            -au \
            -nt AUTO \
            -v \
            --prefix {params.prefix} \
            --undo
        """

