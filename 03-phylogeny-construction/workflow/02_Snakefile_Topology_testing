### need for topology testing 
# testing polyphyly of the N-tail 
# first generate a constrainted tree for the same alignment (see "plot_tree.qmd")
# going to skip the bootstrap, too costly - ran for 7 days and 
# I 'll just reuse the model from the unconstrained "VT+R7' and bootstraps are not needed for topology testing

rule iqtree_Nterm_constrained:
    input:
        aln = "../../data/processed/phylogeny/histones/NTERM_IQTREE/topology_testing/Histone_Curated_Alignment_Unique_Ids_NTERM_revised_CenH3_shared_sequences_NR.fasta",
        cons = "../../data/processed/phylogeny/histones/NTERM_IQTREE/topology_testing/sptree_pruned_shared_only.nwk" # constrained from species tree
    output:
        treefile = "../../data/processed/phylogeny/histones/NTERM_IQTREE/topology_testing/NTERM_constrained_no_boot.treefile",
        log = "../../data/processed/phylogeny/histones/NTERM_IQTREE/topology_testing/NTERM_constrained_no_boot.log",
        iqtree = "../../data/processed/phylogeny/histones/NTERM_IQTREE/topology_testing/NTERM_constrained_no_boot.iqtree"
    threads: 6
    params:
        m = "VT+R7",
        prefix = "../../data/processed/phylogeny/histones/NTERM_IQTREE/topology_testing/NTERM_constrained_no_boot"
    shell:
        """
        ../tools/iqtree-3.0.1-Linux/bin/iqtree3 \
            -s {input.aln} \
            -g {input.cons} \
            -m {params.m} \
            -nt AUTO \
            -v \
            --prefix {params.prefix}
        """

